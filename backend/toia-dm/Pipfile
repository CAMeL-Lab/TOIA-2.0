[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
numpy = ">=1.26,<2"
pandas = ">=2.2,<3"
nltk = "*"
scikit-learn = ">=1.3"
spacy = ">=3.7,<3.9"
# fastapi>=0.137 pulls starlette>=1.1.0, clearing the starlette advisories.
fastapi = ">=0.137"
uvicorn = {extras = ["standard"], version = "*"}
en-core-web-lg = {file = "https://github.com/explosion/spacy-models/releases/download/en_core_web_lg-3.8.0/en_core_web_lg-3.8.0.tar.gz"}
# main.py uses the SQLAlchemy 1.x legacy API (autoload, execute(stmt, **binds)).
sqlalchemy = ">=1.4.54,<2.0"
pydantic = ">=2.9,<3"
cloud-sql-python-connector = ">=1.4"
# Note: the MySQLdb driver is provided in the Docker image via apt
# (python3-mysqldb); it is intentionally not a pip dependency here.
# utils_gpt3.py uses openai.embeddings_utils, removed in openai>=1.0.
openai = "==0.28.1"

[dev-packages]
jupyterlab = "*"
matplotlib = "*"
plotly = "*"

[requires]
python_version = "3.10"
